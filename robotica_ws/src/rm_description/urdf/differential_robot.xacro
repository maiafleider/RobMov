<?xml version="1.0"?>
<robot name="robo_diferencial" xmlns:xacro="http://www.ros.org/wiki/xacro">
<!-- ============================================ -->
<!-- ARQUIVO PRINCIPAL                            -->
<!-- Importa propriedades e macros, define o robô -->
<!-- ============================================ -->
<!-- ==================== -->
<!-- IMPORTAÇÃO DE ARQUIVOS -->
<!-- ==================== -->
<!--
   xacro:include importa o conteúdo de outros arquivos .xacro
   $(find package_name) retorna o caminho do pacote ROS
 -->
  <xacro:include filename="$(find rm_description)/urdf/propriedades_robo.xacro"/>
  <xacro:include filename="$(find rm_description)/urdf/macros.xacro"/>
  <!-- ==================== -->
  <!-- BASE FOOTPRINT       -->
  <!-- ==================== -->
  <link name="base_footprint"/>
  <!-- ==================== -->
  <!-- BASE LINK            -->
  <!-- ==================== -->
  <link name="base_link">
  <visual>
  <origin xyz="0 0 0" rpy="0 0 0"/>
  <geometry> <box size="0.30 0.22 0.08"/> </geometry>
  <material name="blue"/>
  </visual>
  <collision>
  <origin xyz="0 0 0" rpy="0 0 0"/>
  <geometry> <box size="0.30 0.22 0.08"/> </geometry>
  </collision>
  <inertial>
  <origin xyz="0 0 0" rpy="0 0 0"/>
  <mass value="4.0"/>
  <inertia ixx="0.018266667" ixy="0" ixz="0" iyy="0.032133333" iyz="0" izz="0.046133333"/>
  </inertial>
  </link>
  <joint name="base_joint" type="fixed">
  <parent link="base_footprint"/>
  <child link="base_link"/>
  <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>
  <!-- ==================== -->
  <!-- LINK 1 (usando macro) -->
  <!-- ==================== -->
  <!-- TAREFA: Chame o macro cylinder_link para criar o link1 -->
  <!-- Parâmetros: name, length, radius, mass, material -->
  <xacro:cylinder_link
    name="RodaEsc"
    length="${RodaEsc_length}"
    radius="${RodaEsc_radius}"
    mass="${RodaEsc_mass}"
    material="green"/>
  <joint name="jointEsc" type="continuous">
  <parent link="base_link"/>
  <child link="RodaEsc"/>
  <origin xyz="0 0.145 0" rpy="1.57079632679 0 0"/>
  <axis xyz="0 0 -1"/>
  </joint>
  <!-- ==================== -->
  <!-- LINK 2 (usando macro) -->
  <!-- ==================== -->
  <!-- TAREFA: Chame o macro cylinder_link para criar o link2 -->
  <xacro:cylinder_link
    name="RodaDir"
    length="${RodaDir_length}"
    radius="${RodaDir_radius}"
    mass="${RodaDir_mass}"
    material="green"/>
  <joint name="jointDir" type="continuous">
    <parent link="base_link"/>
    <child link="RodaDir"/>
    <origin xyz="0 -0.115 0" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>
  
  <!-- ==================== -->
  <!-- CAMERA LINK -->
  <!-- ==================== -->
  <link name="camera">
    <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
    <box size="0.04 0.04 0.04"/>
    </geometry>
    <material name="gray"/>
    </visual>
    <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
    <box size="0.04 0.04 0.04"/>
    </geometry>
    </collision>
    <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="0.05"/>
    <inertia ixx="0.000013" ixy="0" ixz="0"
                iyy="0.000013" iyz="0"
                izz="0.000013"/>
    </inertial>
  </link>
    <joint name="cam_joint" type="fixed">
      <parent link="base_link"/>
      <child link="camera"/>
      <origin xyz="${0.3/2} 0 0" rpy="0 0 0"/>
    </joint>
    <!-- ==================== -->
    <!-- END EFFECTOR         -->
    <!-- ==================== -->
    <!-- TAREFA: Use o macro sphere_link para criar o end_effector -->
  <link name="end_effector">
    <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
    <sphere radius="${end_effector_radius}"/>
    </geometry>
    <material name="gray"/>
    </visual>
    <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
    <sphere radius="${end_effector_radius}"/>
    </geometry>
    </collision>
    <inertial>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <mass value="${end_effector_mass}"/>
    <inertia ixx="${2.0/5.0 * end_effector_mass * end_effector_radius * end_effector_radius}"
                ixy="0" ixz="0"
                iyy="${2.0/5.0 * end_effector_mass * end_effector_radius * end_effector_radius}"
                iyz="0"
                izz="${2.0/5.0 * end_effector_mass * end_effector_radius * end_effector_radius}"/>
    </inertial>
  </link>
  <joint name="end_effector_joint" type="fixed">
    <parent link="base_link"/>
    <child link="end_effector"/>
    <origin xyz="0 0 ${end_effector_radius - 0.05}" rpy="0 0 0"/>
  </joint>

  <link name = "imu"/>
    <joint name="imu_joint" type="fixed">
      <parent link="base_link"/>
      <child link="imu"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
  
  <!-- ==================== -->
  <!-- LIDAR -->
  <!-- ==================== -->
  <link name="lidar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <cylinder radius="0.04" length="0.02"/>
    </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
  </link>
  
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>
 
</robot>